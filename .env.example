# API Key de OpenAI (obligatorio)
OPENAI_API_KEY=sk-your-api-key-here

# Modelo LLM (default: gpt-4o)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2

# Modelo de embeddings (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=bancoestado_normativas

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
RETRIEVER_K=4

# Directorio de documentos normativos
DATA_DIR=./data
