# GitHub Token (obtener en https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_tu_token_aqui

# URLs de GitHub Models API
GITHUB_BASE_URL=https://models.inference.ai.azure.com
GITHUB_EMBEDDINGS_URL=https://models.github.ai/inference

# Modelo LLM (default: gpt-4.1 via GitHub Models)
LLM_MODEL=gpt-4.1
LLM_TEMPERATURE=0.2

# Modelo de embeddings
EMBEDDING_MODEL=text-embedding-3-small

# FAISS
FAISS_INDEX_DIR=./faiss_index

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
RETRIEVER_K=4

# Directorio de documentos normativos
DATA_DIR=./data
